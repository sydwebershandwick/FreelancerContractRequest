{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vite",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "group": "dev", "panel": "dedicated" },
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "(Local:|ready in).*"
        }
      }
    },
    {
      "label": "Functions",
      "type": "shell",
      "command": "func start",
      "options": { "cwd": "${workspaceFolder}/api" },
      "isBackground": true,
      "presentation": { "group": "dev", "panel": "dedicated" },
      "problemMatcher": {
        "owner": "func",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "(Host lock lease acquired|Worker process started|Functions:).*"
        }
      }
    },
    {
      "label": "Dev: start all",
      "dependsOn": ["Vite", "Functions"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
